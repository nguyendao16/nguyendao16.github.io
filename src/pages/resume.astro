---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import Tag from '../components/Tag.astro';
import { profile } from '../data/profile';
import { site } from '../data/site';

const highlights = profile.resumeHighlights ?? [];
const resumeTags = site.pages.resume.tags ?? [];
---

<BaseLayout title={site.pages.resume.title} description={site.pages.resume.description}>
  <Section
    title={site.pages.resume.title}
    description={site.pages.resume.description}
  >
    <div class="mt-6 flex flex-col gap-3 sm:flex-row">
      <Button href={site.pages.resume.pdfPath} download={site.pages.resume.pdfDownloadName}>
        {site.pages.resume.downloadLabel}
      </Button>
      <Button href="/contact" variant="secondary">{site.pages.resume.contactLabel}</Button>
    </div>
  </Section>

  <Section title={site.pages.resume.highlightsTitle}>
    <div class="mt-6 grid gap-4 lg:grid-cols-[0.9fr_1.1fr]">
      {highlights.length > 0 && (
        <div class="card-muted p-5 sm:p-6">
          <p class="text-label-sm uppercase text-ink-subtle">{site.pages.resume.summaryLabel}</p>
          <ul class="mt-4 space-y-3 text-body-md text-ink-muted">
            {highlights.map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-ink-subtle"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="card overflow-hidden">
        <iframe
          src={site.pages.resume.pdfPath}
          title={site.pages.resume.pdfTitle}
          class="h-[36rem] w-full border-0 bg-surface-container-lowest sm:h-[42rem]"
        ></iframe>
      </div>
    </div>
  </Section>

  {resumeTags.length > 0 && (
    <Section title={site.pages.resume.tagsTitle}>
      <div class="mt-6 flex flex-wrap gap-2">
        {resumeTags.map((tag) => (
          <Tag>{tag}</Tag>
        ))}
      </div>
    </Section>
  )}
</BaseLayout>
