---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SkillBadge from '../components/SkillBadge.astro';
import Tag from '../components/Tag.astro';
import { profile } from '../data/profile';
---

<BaseLayout title="About" description={profile.bio}>
  <section class="site-container py-10 sm:py-14 lg:py-16">
    <div class="mx-auto flex max-w-content flex-col items-center text-center">
      <figure class="card overflow-hidden p-4">
        <img
          src="/images/profile/avatar.svg"
          alt={`${profile.name} portrait`}
          class="h-28 w-28 rounded-card object-cover sm:h-32 sm:w-32"
        />
      </figure>

      <p class="mt-6 text-label-sm uppercase tracking-[0.08em] text-ink-subtle">
        About me
      </p>
      <h1 class="mt-3 font-heading text-display-lg-mobile font-medium tracking-tight text-balance sm:text-display-lg">
        {profile.name}
      </h1>
      <p class="mt-3 text-body-lg text-ink-muted">
        {profile.title}
      </p>
      <p class="mt-5 max-w-reading text-body-md text-ink-muted">
        {profile.bio}
      </p>
    </div>
  </section>

  <Section title="Education">
    <div class="mt-6 grid gap-4">
      {profile.education.map((item) => (
        <article class="card-muted p-5 sm:p-6">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-label-sm uppercase text-ink-subtle">{item.period}</p>
              <h2 class="mt-2 font-heading text-headline-sm font-medium tracking-tight text-ink">
                {item.title}
              </h2>
              <p class="mt-2 text-body-md text-ink-muted">{item.institution}</p>
            </div>
          </div>
          <p class="mt-4 text-body-md text-ink-muted">{item.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section title="Skills">
    <div class="mt-6 flex flex-wrap gap-3">
      {profile.skills.map((skill) => (
        <SkillBadge label={skill} />
      ))}
    </div>
  </Section>

  <Section title="Research interests">
    <div class="mt-6 flex flex-wrap gap-2">
      {profile.researchInterests.map((interest) => (
        <Tag>{interest}</Tag>
      ))}
    </div>
  </Section>

  <Section title="Timeline">
    <ol class="mt-6 space-y-4">
      {profile.timeline.map((item) => (
        <li class="relative pl-14">
          <span class="absolute left-0 top-5 h-5 w-5 rounded-full border border-outline-variant bg-surface-container-lowest"></span>
          <span class="absolute left-2 top-10 h-[calc(100%-1.25rem)] w-px bg-outline-variant"></span>
          <article class="card-muted p-5 sm:p-6">
            <p class="text-label-sm uppercase text-ink-subtle">{item.period}</p>
            <h2 class="mt-2 font-heading text-headline-sm font-medium tracking-tight text-ink">
              {item.title}
            </h2>
            <p class="mt-3 text-body-md text-ink-muted">{item.description}</p>
          </article>
        </li>
      ))}
    </ol>
  </Section>
</BaseLayout>
