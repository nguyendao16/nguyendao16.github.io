---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<BaseLayout title="Projects">
  <Section
    eyebrow="Projects"
    title="Applied machine learning and computer vision work"
    description="Selected projects that show how I approach problem framing, model selection, evaluation, and presentation."
  >
    <div class="mt-6 flex flex-col gap-3 sm:flex-row">
      <Button href="/resume">Resume</Button>
      <Button href="/contact" variant="secondary">Contact</Button>
    </div>
  </Section>

  <Section
    title="Featured projects"
    description="Each project includes the problem statement, tech stack, results, and links for deeper review."
  >
    <div class="mt-8 space-y-8">
      {projects.map((project) => (
        <ProjectCard
          title={project.title}
          description={project.description}
          problemStatement={project.problemStatement}
          techStack={[...project.techStack]}
          metrics={[...project.metrics]}
          githubUrl={project.githubUrl}
          demoUrl={project.demoUrl}
          image={project.image}
          imageAlt={project.imageAlt}
          tags={[...project.tags]}
        />
      ))}
    </div>
  </Section>
</BaseLayout>
