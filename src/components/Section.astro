---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  class: className = '',
} = Astro.props;
---

<section class:list={['site-container py-10 sm:py-14 lg:py-16', className]}>
  {(eyebrow || title || description) && (
    <div class="max-w-content">
      {eyebrow && (
        <p class="font-mono text-label-sm uppercase text-ink-subtle">
          {eyebrow}
        </p>
      )}
      {title && (
        <h2 class="mt-3 border-l-2 border-ink pl-3 text-headline-sm font-medium tracking-tight sm:text-headline-md">
          {title}
        </h2>
      )}
      {description && (
        <p class="mt-3 max-w-reading text-body-md text-ink-muted">
          {description}
        </p>
      )}
    </div>
  )}
  <slot />
</section>
