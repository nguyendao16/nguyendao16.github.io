---
interface Props {
  title: string;
  description: string;
  date: string;
  href: string;
  tags?: string[];
}

const {
  title,
  description,
  date,
  href,
  tags = [],
} = Astro.props;
---

<article class="card-muted">
  <a href={href} class="group block">
    <div class="flex items-stretch justify-between gap-5 p-5 sm:p-6">
      <div class="min-w-0 flex-1 space-y-3">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-label-sm text-ink-subtle">
          <span>{date}</span>
          {tags.length > 0 && <span>{tags[0]}</span>}
        </div>

        <div class="space-y-2">
          <h3 class="font-heading text-headline-sm font-medium tracking-tight transition-colors duration-150 group-hover:text-action">
            {title}
          </h3>
          <p class="max-w-3xl text-body-md text-ink-muted">{description}</p>
        </div>

        {tags.length > 1 && (
          <div class="flex flex-wrap gap-2 pt-1">
            {tags.slice(1).map((tag) => (
              <span class="rounded-pill border border-outline-variant bg-surface-container-low px-3 py-1 text-label-sm text-ink-muted">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>

      <span class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-button border border-outline-variant bg-surface-container-lowest text-ink-subtle transition-colors duration-150 group-hover:bg-surface-container-low group-hover:text-ink">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.8]">
          <path d="M5 12h14" />
          <path d="m13 6 6 6-6 6" />
        </svg>
      </span>
    </div>
  </a>
</article>
