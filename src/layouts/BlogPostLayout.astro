---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/Tag.astro';
import Button from '../components/Button.astro';
import { formatBlogDate } from '../utils/blog';

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  coverImage?: string;
  readingTime?: number;
  headings?: Heading[];
  previous?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
}

const {
  title,
  description,
  date,
  updatedDate,
  tags = [],
  coverImage,
  readingTime,
  headings = [],
  previous,
  next,
} = Astro.props;

const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const metaDescription = description;
---

<BaseLayout title={title} description={metaDescription}>
  <Fragment slot="head">
    <meta name="description" content={metaDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta name="twitter:card" content={coverImage ? 'summary_large_image' : 'summary'} />
    <meta name="article:published_time" content={date.toISOString()} />
    {updatedDate && <meta name="article:modified_time" content={updatedDate.toISOString()} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    {coverImage && <meta property="og:image" content={coverImage} />}
  </Fragment>

  <article class="site-container py-10 sm:py-12 lg:py-16">
    <div class="mx-auto grid max-w-page gap-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-start">
      <div class="min-w-0">
        <div class="max-w-reading space-y-5">
          <div class="flex flex-wrap items-center gap-2">
            <p class="font-mono text-label-sm uppercase tracking-[0.08em] text-ink-subtle">
              Technical blog
            </p>
            {readingTime && (
              <span class="font-mono text-label-sm text-ink-subtle">
                {readingTime} min read
              </span>
            )}
          </div>

          <div class="space-y-4">
            <h1 class="font-heading text-display-md-mobile font-medium tracking-tight text-balance lg:text-display-md">
              {title}
            </h1>
            <p class="text-body-lg text-ink-muted">
              {description}
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-sm text-ink-subtle">
            <span>Published {formatBlogDate(date)}</span>
            {updatedDate && <span>Updated {formatBlogDate(updatedDate)}</span>}
          </div>

          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => <Tag>{tag}</Tag>)}
            </div>
          )}
        </div>

        {coverImage && (
          <figure class="mt-8 overflow-hidden rounded-card border border-outline-variant bg-surface-container-lowest shadow-soft">
            <img src={coverImage} alt={title} class="aspect-[16/9] w-full object-cover" />
          </figure>
        )}

        <div class="mt-10 max-w-reading">
          <div class="blog-content">
            <slot />
          </div>
        </div>

        <div class="mt-12 grid gap-4 border-t border-outline-variant pt-8 sm:grid-cols-2">
          {previous ? (
            <a
              href={`/blog/${previous.slug}/`}
              class="card-muted block p-5 transition-colors duration-150 hover:border-outline hover:bg-surface-container"
            >
              <p class="text-label-sm uppercase text-ink-subtle">Previous post</p>
              <p class="mt-2 font-heading text-headline-sm font-medium tracking-tight text-ink">
                {previous.data.title}
              </p>
              <p class="mt-2 text-sm text-ink-muted">{previous.data.description}</p>
            </a>
          ) : (
            <div class="card-muted p-5">
              <p class="text-label-sm uppercase text-ink-subtle">Previous post</p>
              <p class="mt-2 text-sm text-ink-muted">No earlier post available.</p>
            </div>
          )}

          {next ? (
            <a
              href={`/blog/${next.slug}/`}
              class="card-muted block p-5 transition-colors duration-150 hover:border-outline hover:bg-surface-container"
            >
              <p class="text-label-sm uppercase text-ink-subtle">Next post</p>
              <p class="mt-2 font-heading text-headline-sm font-medium tracking-tight text-ink">
                {next.data.title}
              </p>
              <p class="mt-2 text-sm text-ink-muted">{next.data.description}</p>
            </a>
          ) : (
            <div class="card-muted p-5">
              <p class="text-label-sm uppercase text-ink-subtle">Next post</p>
              <p class="mt-2 text-sm text-ink-muted">No newer post available.</p>
            </div>
          )}
        </div>

        <div class="mt-8">
          <Button href="/blog" variant="secondary">
            Back to blog
          </Button>
        </div>
      </div>

      <aside class="lg:sticky lg:top-24">
        <div class="card-muted p-5">
          <p class="text-label-sm uppercase text-ink-subtle">Table of contents</p>
          {tocHeadings.length > 0 ? (
            <nav aria-label="Table of contents" class="mt-4">
              <ul class="space-y-2">
                {tocHeadings.map((heading) => (
                  <li class:list={heading.depth === 3 ? 'pl-4' : ''}>
                    <a
                      href={`#${heading.slug}`}
                      class="link-muted text-sm"
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          ) : (
            <p class="mt-4 text-sm text-ink-muted">
              Headings will appear here when the article includes sections.
            </p>
          )}
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
